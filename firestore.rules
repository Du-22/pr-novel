// ============================================
// Firestore Security Rules
// 用途: 管控所有 Collection 的讀寫權限
// 更新日期: 2026-03-19
// ============================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== 輔助函式 ==========

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.uid == "gFwOsNadC9MoPzPdrn85H09AtVt2";
    }


    // ========== 收藏 (favorites) ==========
    match /favorites/{userId}/novels/{novelId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }


    // ========== 書籤 (bookmarks) ==========
    match /bookmarks/{userId}/novels/{novelId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }


    // ========== 閱讀記錄 (readHistory) ==========
    match /readHistory/{userId}/novels/{novelId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }


    // ========== 小說 (novels) ==========
    match /novels/{novelId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.authorUid == request.auth.uid;

      // 作者可更新所有欄位；任何人（含未登入）可更新 stats（閱讀數/收藏數）
      allow update: if (isSignedIn() && resource.data.authorUid == request.auth.uid)
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats']);

      allow delete: if isSignedIn()
                    && resource.data.authorUid == request.auth.uid
                    && resource.data.get('isOfficial', false) == false;
    }

    // ========== 章節子集合 (novels/{novelId}/chapters) ==========
    match /novels/{novelId}/chapters/{chapterNumber} {
      allow read: if true;

      allow write: if isSignedIn()
                   && get(/databases/$(database)/documents/novels/$(novelId)).data.authorUid == request.auth.uid;
    }


    // ========== 評分 (ratings) ==========
    // 評分統計文件（ratingSum, ratingCount）
    match /ratings/{novelId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 個人評分記錄
    match /ratings/{novelId}/users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }


    // ========== 評論 (comments) ==========
    // 計數器文件（記錄每本小說的 topLevelCount）
    match /comments/{novelId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 留言與回覆
    match /comments/{novelId}/items/{commentId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.authorUid == request.auth.uid;

      // 本人可更新所有欄位；任何登入者可更新 replyCount 和 likedBy（transaction / 按讚）
      allow update: if isSignedIn() && (
        resource.data.authorUid == request.auth.uid ||
        isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount', 'likedBy'])
      );

      allow delete: if isSignedIn()
                    && (resource.data.authorUid == request.auth.uid || isAdmin());
    }


    // ========== 通知 (notifications) ==========
    match /notifications/{userId}/items/{notificationId} {
      // 只有本人可以讀取、更新（已讀）、刪除自己的通知
      allow read, update, delete: if isOwner(userId);
      // 任何已登入使用者都可以建立通知（給他人發送通知）
      allow create: if isSignedIn();
    }


    // ========== 使用者資料 (users) - 未來使用 ==========
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }


    // ========== 檢舉 (reports) ==========
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update: if isAdmin();
      allow delete: if false;
    }


    // ========== 預設規則: 拒絕所有未明確設定的 Collection ==========
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
